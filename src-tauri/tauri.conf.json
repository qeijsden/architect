{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Architect",
  "version": "0.5.3",
  "identifier": "com.architect.game",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Architect",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Game",
    "shortDescription": "Architect",
    "macOS": {
      "files": {
        "MacOS/libsteam_api.dylib": "steamworks/osx/libsteam_api.dylib",
        "MacOS/steam_appid.txt": "steam_appid.txt"
      }
    },
    "resources": [
      "steamworks/win64/steam_api64.dll",
      "steamworks/win64/steam_api64.lib",
      "steamworks/osx/libsteam_api.dylib",
      "steam_appid.txt"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
